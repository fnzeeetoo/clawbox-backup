# Clawbox Backup Environment Configuration

# API server on the clawbox host (used by web UI to connect)
BACKUP_API_URL=http://localhost:18789

# Optional: Webhook URL for backup notifications
# WEBHOOK_URL=https://your-notification-endpoint.com/backup

# Optional: Dropbox access token (or configure in config.json)
# DROPBOX_ACCESS_TOKEN=sl.xxx

# Configuration file path (used by the backup engine service)
# CONFIG_PATH=/etc/clawbox-backup/config.json